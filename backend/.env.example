HEALTH_AI_API=your_gemini_api_key_here
DATABASE_URL=sqlite:///./tonyhealth.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://prashant-singh-rawat.github.io

# ─── n8n Webhook Configuration ───────────────────────────────────────────────
# Set N8N_BASE_URL to your n8n instance (local or cloud)
N8N_BASE_URL=http://localhost:5678

# Individual webhook URLs (auto-built from N8N_BASE_URL if left blank)
N8N_HIGH_RISK_WEBHOOK=http://localhost:5678/webhook/heart-ai/high-risk-alert
N8N_REPORT_SAVED_WEBHOOK=http://localhost:5678/webhook/heart-ai/report-saved
N8N_DOCTOR_ALERT_WEBHOOK=http://localhost:5678/webhook/heart-ai/doctor-alert

# Risk thresholds
HIGH_RISK_THRESHOLD=70.0
CRITICAL_RISK_THRESHOLD=85.0

# Doctor to notify for critical alerts
DOCTOR_EMAIL=doctor@hospital.com
